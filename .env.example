# === Django ===
DJANGO_SECRET_KEY=change-me-in-production-use-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx
DJANGO_SETTINGS_MODULE=config.settings.development
# Nivel de log root (INFO, DEBUG, WARNING)
DJANGO_LOG_LEVEL=INFO

# === Database (PostgreSQL) ===
POSTGRES_DB=seeds_erp
POSTGRES_USER=seeds_user
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# === Redis ===
REDIS_URL=redis://redis:6379/0
# DB separada para contadores de cuota IA (tokens/día por conversación)
REDIS_CACHE_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# === JWT ===
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost

# === WhatsApp API (Meta Cloud API) — Fase 3+ ===
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# App Secret (Meta dashboard) — verificación X-Hub-Signature-256 en webhooks
WHATSAPP_APP_SECRET=
# Límite de envíos salientes por minuto y por número destino (Cloud API)
WHATSAPP_MAX_SENDS_PER_MINUTE=60

# === OpenAI API (respuestas IA en chat — Fase 4) ===
OPENAI_API_KEY=
# Desactivar moderación de salidas (solo emergencia; no en producción)
# OPENAI_MODERATION_DISABLED=true
# Opcionales (la app IA usa el modelo en AIConfiguration; estos son referencia / futuro RAG)
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# RAG: reindexación automática al subir documentos CRM (requiere OPENAI_API_KEY)

# === Email ===
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# === Files ===
MAX_UPLOAD_SIZE_MB=10
MEDIA_URL=/media/
STATIC_URL=/static/

# === CRM ===
CRM_STALE_CONTACT_DAYS=14

# === Seed (scripts/seed_data.py) ===
# SEED_DEMO=1 crea empresa + contacto demo si no existen

# === Producción (HTTPS detrás de proxy) ===
# Tras validar TLS, activar HSTS (segundos). 0 = desactivado.
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_PRELOAD=False
# DJANGO_SECURE_SSL_REDIRECT=True
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
#
# Build del frontend (docker-compose.production.yml):
# VITE_API_URL=https://tu-dominio.com/api/v1
# VITE_WS_URL=wss://tu-dominio.com/ws
# (Mismo origen: VITE_API_URL=/api/v1 y VITE_WS_URL vacío → el SPA usa wss según la página.)

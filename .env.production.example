# === Django ===
DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=erp.tu-dominio.com,localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_PRELOAD=False

# === Database (PostgreSQL) ===
POSTGRES_DB=seeds_erp
POSTGRES_USER=seeds_user
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# === Redis / Celery ===
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# === CORS ===
CORS_ALLOWED_ORIGINS=https://erp.tu-dominio.com

# === Frontend build-time vars (usadas por docker compose build) ===
VITE_API_URL=/api/v1
VITE_WS_URL=wss://erp.tu-dominio.com/ws

# === WhatsApp (opcional, si integras canal WA) ===
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_MAX_SENDS_PER_MINUTE=60

# === OpenAI (opcional, para respuestas IA) ===
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Email (opcional) ===
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# === Sentry (opcional) ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
